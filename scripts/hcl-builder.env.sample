# HCL Builder config — copy to your own file and pass with -c
#
# Usage: hcl-builder.sh -c ~/.hcl/my-lab.env -i manila,octavia,trove,cinder,k9s
#
# All values can also be set via environment variables or CLI flags.
# Precedence: flags > env vars > config file > defaults

ACME_EMAIL="you@example.com"
GATEWAY_DOMAIN="cluster.local"
OS_CLOUD="<OPENSTACK_PROD_CLOUD_TO_DEPLOY_LAB_ON from clouds.yaml>"
OS_FLAVOR="gp.0.8.24"
OS_IMAGE="Ubuntu 24.04"
LAB_NAME_PREFIX="hyperconverged"

# Set to "true" to rsync your local genestack checkout to the jump host
# instead of cloning from GitHub. Useful for development.
HYPERCONVERGED_DEV="false"

# SSH username — auto-detected from image if not set
# SSH_USERNAME="ubuntu"

# ---------------------------------------------------------------------------
# Balabit gateway routing (optional — Rackspace internal labs)
# ---------------------------------------------------------------------------
# When the lab's outer cloud sits behind a Balabit Shell Control Box
# gateway (e.g., Rackspace internal labs), set BALABIT_GATEWAY to route
# every ssh/scp/rsync through the gateway using its inband
# `gu=USER@DEST@VIP@GATEWAY` form. The script opens a single SSH
# ControlMaster connection to the gateway at the start of the run and
# every subsequent ssh/scp/rsync rides that socket — first connect costs
# ~10s of gateway-auth latency, every call after is local-fast. Trap
# tears the master socket down on exit. No second terminal, no SSH
# config edits, no manual cleanup.
#
# Why ControlMaster instead of a port-forward tunnel: Balabit's session
# policy blocks `direct-tcpip` channels (i.e., `ssh -L`). A `-L` forward
# returns success and the local listener binds, but bytes silently go
# nowhere. ControlMaster reuses the same authenticated session for
# multiple commands, which Balabit does allow.
#
# Auth to the gateway uses your normal SSH agent (e.g., 1Password).
# Legacy crypto (dh-group1-sha1 Kex, aes128-ctr family Ciphers, hmac-sha2
# MACs) is passed inline via -o flags — you do NOT need a
# `Host support.*.gateway.rackspace.com` stanza in ~/.ssh/config.
#
# Leave BALABIT_GATEWAY unset for clouds that don't use Balabit.
#
# BALABIT_GATEWAY="support.dfw1.gateway.rackspace.com"
# BALABIT_USER="dani2143"           # gateway login username; defaults to $USER
# BALABIT_DEST_USER="ubuntu"        # username on the lab worker; defaults to $SSH_USERNAME
