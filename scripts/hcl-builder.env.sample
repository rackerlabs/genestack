# HCL Builder config — copy to your own file and pass with -c
#
# Usage: hcl-builder.sh -c ~/.hcl/my-lab.env -i manila,octavia,trove,cinder,k9s
#
# All values can also be set via environment variables or CLI flags.
# Precedence: flags > env vars > config file > defaults

ACME_EMAIL="you@example.com"
GATEWAY_DOMAIN="cluster.local"
OS_CLOUD="<OPENSTACK_PROD_CLOUD_TO_DEPLOY_LAB_ON from clouds.yaml>"
OS_FLAVOR="gp.0.8.24"
OS_IMAGE="Ubuntu 24.04"
LAB_NAME_PREFIX="hyperconverged"

# Set to "true" to rsync your local genestack checkout to the jump host
# instead of cloning from GitHub. Useful for development.
HYPERCONVERGED_DEV="false"

# SSH username — auto-detected from image if not set
# SSH_USERNAME="ubuntu"
