---
images:
  tags:
    bootstrap: "ghcr.io/rackerlabs/genestack-images/openstack-client:latest"
    trove_api: "ghcr.io/rackerlabs/genestack-images/trove:2025.1-latest"
    trove_conductor: "ghcr.io/rackerlabs/genestack-images/trove:2025.1-latest"
    trove_taskmanager: "ghcr.io/rackerlabs/genestack-images/trove:2025.1-latest"
    trove_db_sync: "ghcr.io/rackerlabs/genestack-images/trove:2025.1-latest"
    db_drop: "ghcr.io/rackerlabs/genestack-images/openstack-client:latest"
    db_init: "ghcr.io/rackerlabs/genestack-images/openstack-client:latest"
    dep_check: "ghcr.io/rackerlabs/genestack-images/kubernetes-entrypoint:latest"
    image_repo_sync: null
    ks_endpoints: "ghcr.io/rackerlabs/genestack-images/openstack-client:latest"
    ks_service: "ghcr.io/rackerlabs/genestack-images/openstack-client:latest"
    ks_user: "ghcr.io/rackerlabs/genestack-images/openstack-client:latest"
    rabbit_init: null
    test: null
pod:
  resources:
    enabled: false
conf:
  trove:
    DEFAULT:
      trove_api_workers: 1
      management_networks: "{{ trove_management_network_id | default('') }}"
      management_security_groups: "{{ trove_management_secgroup_id | default('') }}"
      nova_keypair: "{{ trove_keypair_name }}"
    network:
      enable_access_check: false
      # network_isolation=true makes the guest agent bring down the
      # customer-tenant NIC during prepare, which kills internet access
      # the agent needs to docker pull mysql. Disable so ens3 stays up
      # and prepare can pull the datastore image.
      network_isolation: false
    oslo_messaging_notifications:
      driver: noop
    # Disable quorum queues so the conductor and the trove-guestagent
    # (which has no built-in option to enable them — even oslo
    # rabbit_quorum_queue=true via /etc/trove/conf.d isn't applied to its
    # consumer queue declaration) agree on plain classic non-durable
    # queues. Without this, the conductor declares "guestagent.<id>" as
    # quorum/durable=true, the agent's declare with durable=false fails
    # PRECONDITION_FAILED, and the agent crashloops.
    oslo_messaging_rabbit:
      rabbit_quorum_queue: false
      rabbit_transient_quorum_queue: false
      amqp_durable_queues: false
  trove_api_uwsgi:
    uwsgi:
      processes: 1
      threads: 1
