#!/bin/bash
# Install Docker CE from Docker's official Debian repository.
if [ ${DIB_DEBUG_TRACE:-0} -gt 0 ]; then
    set -x
fi
set -eu
set -o pipefail

GUEST_USERNAME=${GUEST_USERNAME:-"debian"}

echo "Installing Docker CE for Debian"
export DEBIAN_FRONTEND=noninteractive

# Install prerequisites
apt-get update -qq
apt-get install -y -qq ca-certificates curl gnupg lsb-release >/dev/null

# Add Docker's official GPG key (modern method, not deprecated apt-key)
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/debian/gpg \
    | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg

# Add Docker apt repository for Debian
CODENAME=$(lsb_release -cs)
cat > /etc/apt/sources.list.d/docker.list << DOCKEREOF
deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian ${CODENAME} stable
DOCKEREOF

apt-get update -qq
apt-get install -y -qq docker-ce docker-ce-cli containerd.io >/dev/null
apt-get clean

# Enable Docker at boot
systemctl enable docker

echo "Adding ${GUEST_USERNAME} user to docker group"
usermod -aG docker ${GUEST_USERNAME}

echo ">>> Docker CE installed successfully for Debian ${CODENAME}."
