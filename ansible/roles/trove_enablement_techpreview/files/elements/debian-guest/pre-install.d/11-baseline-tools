#!/bin/bash
# Install baseline packages and tools for Debian.
set -e
set -o xtrace

export DEBIAN_FRONTEND=noninteractive

apt-get update -qq
apt-get install -y -qq \
    apt-transport-https \
    ca-certificates \
    curl \
    default-mysql-client \
    gnupg \
    lsb-release \
    sudo \
    chrony >/dev/null
