[
    {
        "op": "add",
        "path": "/spec/listeners/-",
        "value": {
            "name": "trove-https",
            "port": 443,
            "protocol": "HTTPS",
            "hostname": "{{trove_gateway_hostname}}",
            "allowedRoutes": {
                "namespaces": {
                    "from": "All"
                }
            },
            "tls": {
                "certificateRefs": [
                    {
                        "group": "",
                        "kind": "Secret",
                        "name": "trove-gw-tls-secret"
                    }
                ],
                "mode": "Terminate"
            }
        }
    }
]
