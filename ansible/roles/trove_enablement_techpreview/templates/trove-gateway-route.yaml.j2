---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: trove-gateway-route
  namespace: openstack
  labels:
    application: gateway-api
    service: HTTPRoute
    route: trove
spec:
  parentRefs:
    - name: flex-gateway
      sectionName: trove-https
      namespace: envoy-gateway
      group: gateway.networking.k8s.io
      kind: Gateway
  hostnames:
    - "{{trove_gateway_hostname}}"
  rules:
    - backendRefs:
        - name: trove-api
          port: 8779
          group: ""
          kind: Service
          weight: 1
      matches:
        - path:
            type: PathPrefix
            value: /
      timeouts:
        request: 120s
